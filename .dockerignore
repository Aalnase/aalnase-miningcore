# Git metadata is intentionally included.
# GitVersion.MsBuild needs .git during dotnet publish.

# Local build outputs
build/
build.*/
build.new/
build.test/
build.prev*/
bin/
obj/
**/bin/
**/obj/

# Native build outputs
src/Native/libxelishashv3/build/
external/xelis-hash/C/build/

# Local runtime configuration and secrets
config.json
*.wallet
*.wallet.*
*.keys
.rpcpass
.rpcuser
.wallet_pass
.wallet_rpc_pass
.api_key
*.env
.env

# Runtime data, local caches and temporary directories
data/
runtime/
cache/
tmp/
temp/
logs/
*.log
*.sql
*.dump

# Local backups and archives
backup/
backups/
*.backup/
*.bak
*.tar.gz
*.zip
